{
  "eslint.packageManager": "yarn",
  "eslint.autoFixOnSave": true,
  "prettier.eslintIntegration": true,
  "typescript.preferences.quoteStyle": "double",
  "javascript.preferences.quoteStyle": "double",
  "python.pythonPath": "python3",
  "pyright.organizeimports.provider": "pyright",
  "pyright.disableDiagnostics": true,
  "python.analysis.typeCheckingMode": "strict",
  "python.formatting.provider": "black",
  "python.formatting.blackPath": "~/.local/bin/black",
  "python.formatting.blackArgs": ["--line-length=79"],
  "python.linting.enabled": true,
  "python.linting.lintOnSave": true,
  "python.linting.flake8Enabled": true,
  "python.linting.flake8Path": "~/.local/bin/flake8",
  "python.linting.flake8Args": ["--ignore=F405,F403,W504,W503,E203"],
  "python.linting.mypyEnabled": true,
  "python.linting.mypyPath": "~/.local/bin/mypy",
  "python.linting.mypyArgs": [
    "--strict",
    "--strict-equality",
    "--ignore-missing-imports",
    "--follow-imports=silent",
    "--show-column-numbers"
  ],
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
      "args": ["serve"],
      "filetypes": ["terraform", "tf"],
      "initializationOptions": {},
      "settings": {}
    }
  }
}
